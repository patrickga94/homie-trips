# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database. Set this to your Neon pooled connection string to develop against
# shared/production data, or leave the local value for an isolated local DB.
DATABASE_URL=postgres://trip:trip@localhost:5432/trip_app

# `manage.py test` ALWAYS uses a local database (never DATABASE_URL), so the
# test suite can't touch production. Override the local test DB here if needed.
# TEST_DATABASE_URL=postgres://trip:trip@localhost:5432/trip_app
