# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database. Local dev via docker-compose uses the value below.
# In production set this to your Neon pooled connection string.
DATABASE_URL=postgres://trip:trip@localhost:5432/trip_app
