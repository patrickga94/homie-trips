# flyctl launch added from .gitignore
# Python / Django
**/__pycache__
**/*.py[cod]
**/*.egg-info
**/.venv
**/venv
**/backend/.env
**/backend/staticfiles
**/backend/spa
**/*.sqlite3

# Node / Vite
**/node_modules
**/frontend/dist
**/frontend/.env.local
**/npm-debug.log*
**/yarn-error.log*

# Editors / OS
**/.DS_Store
**/.idea
**/.vscode
**/*.swp

# flyctl launch added from .idea/.gitignore
# Default ignored files
.idea/shelf
.idea/workspace.xml
# Editor-based HTTP Client requests
.idea/httpRequests
# Datasource local storage ignored files
.idea/dataSources
.idea/dataSources.local.xml

# flyctl launch added from backend/.idea/.gitignore
# Default ignored files
backend/.idea/shelf
backend/.idea/workspace.xml
# Editor-based HTTP Client requests
backend/.idea/httpRequests
# Datasource local storage ignored files
backend/.idea/dataSources
backend/.idea/dataSources.local.xml
fly.toml
